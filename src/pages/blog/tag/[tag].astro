---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const tagMap = new Map<string, typeof allPosts>();

  for (const post of allPosts) {
    for (const tag of (post.data.tags ?? [])) {
      const key = tag.toLowerCase();
      if (!tagMap.has(key)) tagMap.set(key, []);
      tagMap.get(key)!.push(post);
    }
  }

  return Array.from(tagMap.entries()).flatMap(([tag, posts]) => [
    {
      params: { tag },
      props: { displayTag: posts[0].data.tags?.find(t => t.toLowerCase() === tag) ?? tag, posts },
    },
  ]);
}

const { tag } = Astro.params;
const { displayTag, posts } = Astro.props;
const sorted = posts.sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`${displayTag} の記事一覧 | TechBoost`}
      description={`${displayTag} に関する技術記事 ${posts.length}件。エンジニア向け実践的な情報をお届けします。`}
    />
    <style>
      .tag-hero {
        padding: 3rem 1.5rem 2rem;
        text-align: center;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .tag-badge {
        display: inline-block;
        background: rgb(var(--accent) / 0.12);
        border: 1px solid rgb(var(--accent) / 0.35);
        color: rgb(var(--accent));
        padding: 0.3rem 1rem;
        border-radius: 9999px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }
      .tag-hero h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: rgb(var(--black));
        margin: 0 0 0.5rem;
      }
      .tag-hero p { color: rgb(var(--gray)); margin: 0; }
      .posts-grid {
        max-width: 1100px;
        margin: 2.5rem auto;
        padding: 0 1.5rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
      }
      .post-card {
        background: var(--color-surface-variant);
        border: 1px solid rgb(var(--gray-light));
        border-radius: 0.75rem;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
      }
      .post-card:hover { border-color: rgb(var(--accent) / 0.4); transform: translateY(-2px); }
      .post-card img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
      }
      .post-card-body { padding: 1rem 1.2rem 1.2rem; flex: 1; display: flex; flex-direction: column; }
      .post-date { font-size: 0.75rem; color: rgb(var(--gray)); margin-bottom: 0.5rem; }
      .post-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: rgb(var(--gray-dark));
        line-height: 1.5;
        flex: 1;
      }
      .post-tags { margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.3rem; }
      .post-tag {
        font-size: 0.7rem;
        background: rgb(var(--gray-light));
        color: rgb(var(--accent));
        padding: 0.15rem 0.5rem;
        border-radius: 9999px;
      }
      .back-link {
        display: inline-block;
        margin: 0 1.5rem 1.5rem;
        color: rgb(var(--accent));
        text-decoration: none;
        font-size: 0.9rem;
      }
      .back-link:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="tag-hero">
        <span class="tag-badge">タグ</span>
        <h1>{displayTag}</h1>
        <p>{sorted.length} 件の記事</p>
      </div>
      <a href="/blog/tags" class="back-link">← タグ一覧に戻る</a>
      <div class="posts-grid">
        {sorted.map((post: any) => (
          <a href={`/blog/${post.id}`} class="post-card">
            {post.data.heroImage && (
              <img src={post.data.heroImage.src ?? post.data.heroImage} alt={post.data.title} loading="lazy" />
            )}
            <div class="post-card-body">
              <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
              <p class="post-title">{post.data.title}</p>
              {post.data.tags && (
                <div class="post-tags">
                  {(post.data.tags as string[]).slice(0, 3).map((t: string) => (
                    <span class="post-tag">{t}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
