---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const allPosts = await getCollection('blog');
const tagMap = new Map<string, number>();

for (const post of allPosts) {
  for (const tag of (post.data.tags ?? [])) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}

const tags = Array.from(tagMap.entries())
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title="タグ一覧 | TechBoost"
      description="TechBoostの全タグ一覧。React・TypeScript・Docker・AIなど技術タグで記事を絞り込めます。"
    />
    <style>
      body { background: #0a1628; color: #e2e8f0; }
      .tags-hero {
        padding: 3rem 1.5rem 2rem;
        text-align: center;
        border-bottom: 1px solid #1e3a5f;
      }
      .tags-hero h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: #f0f4f8;
        margin: 0 0 0.5rem;
      }
      .tags-hero p { color: #94a3b8; margin: 0; }
      .tags-container {
        max-width: 900px;
        margin: 2.5rem auto;
        padding: 0 1.5rem;
      }
      .tags-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }
      .tag-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #0f2035;
        border: 1px solid #1e3a5f;
        color: #7dd3fc;
        text-decoration: none;
        padding: 0.4rem 0.9rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        transition: all 0.2s;
      }
      .tag-link:hover {
        background: #00d4ff22;
        border-color: #00d4ff55;
        color: #00d4ff;
      }
      .tag-count {
        font-size: 0.75rem;
        color: #64748b;
        background: #1e3a5f;
        padding: 0.1rem 0.4rem;
        border-radius: 9999px;
      }
      .section-title {
        font-size: 1rem;
        color: #64748b;
        margin: 0 0 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #1e3a5f;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="tags-hero">
        <h1>タグ一覧</h1>
        <p>全 {tags.length} タグ · {allPosts.length} 記事</p>
      </div>
      <div class="tags-container">
        <p class="section-title">記事数の多い順</p>
        <div class="tags-cloud">
          {tags.map(({ tag, count }) => (
            <a href={`/blog/tag/${encodeURIComponent(tag.toLowerCase())}`} class="tag-link">
              {tag}
              <span class="tag-count">{count}</span>
            </a>
          ))}
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
