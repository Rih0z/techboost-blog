---
// Cross-platform CTA: note + BOOTH + DevToolBox (tag-aware tool recommendations)
interface Props {
  title?: string;
  description?: string;
  tags?: string[];
}
const { title = '', description = '', tags = [] } = Astro.props;

// Tag-based DevToolBox tool recommendations
const tagStr = (tags.join(' ') + ' ' + title + ' ' + description).toLowerCase();

interface ToolRec { href: string; label: string }
const toolRecs: ToolRec[] = [];

const toolMap: { pattern: RegExp; tools: ToolRec[] }[] = [
  { pattern: /json|api|rest/, tools: [
    { href: 'https://usedevtools.com/json-formatter', label: 'JSON整形ツール' },
    { href: 'https://usedevtools.com/json-path', label: 'JSONPathテスター' },
  ]},
  { pattern: /jwt|認証|auth/, tools: [
    { href: 'https://usedevtools.com/jwt-decoder', label: 'JWTデコーダー' },
    { href: 'https://usedevtools.com/jwt-builder', label: 'JWTビルダー' },
  ]},
  { pattern: /typescript|型|type/, tools: [
    { href: 'https://usedevtools.com/json-to-ts', label: 'JSON→TypeScript変換' },
  ]},
  { pattern: /正規表現|regex|パターン/, tools: [
    { href: 'https://usedevtools.com/regex-tester', label: '正規表現テスター' },
    { href: 'https://usedevtools.com/ai-regex', label: 'AI正規表現生成' },
  ]},
  { pattern: /css|スタイル|tailwind|デザイン/, tools: [
    { href: 'https://usedevtools.com/css-unit', label: 'CSS単位変換' },
    { href: 'https://usedevtools.com/color-contrast', label: 'コントラストチェッカー' },
    { href: 'https://usedevtools.com/css-gradient', label: 'CSSグラデーション' },
  ]},
  { pattern: /セキュリティ|security|暗号|hash|crypto/, tools: [
    { href: 'https://usedevtools.com/hash-generator', label: 'ハッシュ生成' },
    { href: 'https://usedevtools.com/password-generator', label: 'パスワード生成' },
  ]},
  { pattern: /base64|エンコード|encode/, tools: [
    { href: 'https://usedevtools.com/base64', label: 'Base64変換' },
    { href: 'https://usedevtools.com/url-encode', label: 'URLエンコード' },
  ]},
  { pattern: /git|diff|バージョン/, tools: [
    { href: 'https://usedevtools.com/diff', label: 'テキスト差分比較' },
    { href: 'https://usedevtools.com/semver', label: 'セマンティックバージョニング' },
  ]},
  { pattern: /sql|データベース|db/, tools: [
    { href: 'https://usedevtools.com/sql-formatter', label: 'SQLフォーマッター' },
  ]},
  { pattern: /markdown|md|ブログ|astro/, tools: [
    { href: 'https://usedevtools.com/markdown-html', label: 'Markdown→HTML変換' },
  ]},
  { pattern: /yaml|設定ファイル|config/, tools: [
    { href: 'https://usedevtools.com/json-yaml', label: 'JSON⇔YAML変換' },
    { href: 'https://usedevtools.com/env-parser', label: '.env パーサー' },
  ]},
  { pattern: /日時|timestamp|temporal|時間/, tools: [
    { href: 'https://usedevtools.com/timestamp', label: 'タイムスタンプ変換' },
    { href: 'https://usedevtools.com/timezone', label: 'タイムゾーン変換' },
  ]},
  { pattern: /uuid|id|識別子/, tools: [
    { href: 'https://usedevtools.com/uuid', label: 'UUID生成' },
  ]},
  { pattern: /cron|定期実行|スケジュール|github actions/, tools: [
    { href: 'https://usedevtools.com/cron-builder', label: 'Cron式ビルダー' },
  ]},
  { pattern: /svg|画像|image/, tools: [
    { href: 'https://usedevtools.com/svg-optimizer', label: 'SVG最適化' },
  ]},
  { pattern: /linux|シェル|コマンド|chmod/, tools: [
    { href: 'https://usedevtools.com/chmod-calculator', label: 'chmod計算機' },
  ]},
  { pattern: /カラー|color|配色/, tools: [
    { href: 'https://usedevtools.com/color-palette', label: 'カラーパレット生成' },
    { href: 'https://usedevtools.com/color-converter', label: 'カラー変換' },
  ]},
];

const seen = new Set<string>();
for (const { pattern, tools } of toolMap) {
  if (pattern.test(tagStr)) {
    for (const tool of tools) {
      if (!seen.has(tool.href) && toolRecs.length < 3) {
        seen.add(tool.href);
        toolRecs.push(tool);
      }
    }
  }
}
---

<aside class="cross-platform-cta" aria-label="関連サービス">
  <h3 class="cta-heading">さらに学びを深める</h3>
  <div class="cta-grid">
    <a href="https://note.com/ezark_company" target="_blank" rel="noopener noreferrer" class="cta-card cta-card--note">
      <span class="cta-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </span>
      <div class="cta-text">
        <span class="cta-label">note</span>
        <span class="cta-title">AI実践ワークフロー・事業計画テンプレート</span>
        <span class="cta-action">無料で読む &rarr;</span>
      </div>
    </a>
    <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener noreferrer" class="cta-card cta-card--booth">
      <span class="cta-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </span>
      <div class="cta-text">
        <span class="cta-label">BOOTH</span>
        <span class="cta-title">チートシート・テンプレート集（PDF/Markdown）</span>
        <span class="cta-action">&yen;490〜 &rarr;</span>
      </div>
    </a>
    <div class="cta-card cta-card--devtools">
      <span class="cta-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      </span>
      <div class="cta-text">
        <span class="cta-label">DevToolBox</span>
        {toolRecs.length > 0 ? (
          <span class="cta-title">この記事に関連する無料ツール</span>
          <ul class="devtools-links">
            {toolRecs.map((tool) => (
              <li>
                <a href={tool.href} target="_blank" rel="noopener noreferrer">
                  {tool.label} &rarr;
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <a href="https://usedevtools.com/" target="_blank" rel="noopener noreferrer" class="cta-title-link">
            <span class="cta-title">無料オンライン開発ツール46種</span>
            <span class="cta-action">ツールを使う &rarr;</span>
          </a>
        )}
      </div>
    </div>
  </div>
</aside>

<style>
  .cross-platform-cta {
    margin-top: 2.5rem;
    padding: 1.5rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(var(--accent) / 0.06), rgb(var(--accent) / 0.02));
    border: 1px solid rgb(var(--accent) / 0.15);
  }

  .cta-heading {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: rgb(var(--black));
    text-align: center;
  }

  .cta-grid {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cta-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    background: white;
    border: 1px solid rgb(var(--gray-light));
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .cta-card:hover {
    border-color: rgb(var(--accent));
    box-shadow: 0 2px 8px rgb(var(--accent) / 0.1);
  }

  .cta-icon {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    margin-top: 0.125rem;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .cta-label {
    font-size: 0.6875rem;
    font-weight: 700;
    color: rgb(var(--accent));
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cta-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--gray-dark));
    line-height: 1.4;
  }

  .cta-title-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .cta-action {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgb(var(--accent));
    margin-top: 0.125rem;
  }

  .devtools-links {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .devtools-links li a {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgb(var(--accent));
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .devtools-links li a:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  @media (min-width: 640px) {
    .cta-grid {
      flex-direction: row;
    }
    .cta-card {
      flex: 1;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .cta-text {
      align-items: center;
    }
    .devtools-links {
      align-items: center;
    }
  }
</style>
