---
interface Product {
  name: string;
  price: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
}

const { title = '', description = '' } = Astro.props;

// タイトルと説明文から技術キーワードを抽出してBOOTH商品を推奨
const content = `${title} ${description}`.toLowerCase();

let recommendedProduct: Product;

if (content.includes('react') || content.includes('リアクト')) {
  recommendedProduct = {
    name: 'Reactチートシート完全版',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968016'
  };
} else if (content.includes('python') || content.includes('パイソン')) {
  recommendedProduct = {
    name: 'Python完全チートシート',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968032'
  };
} else if (content.includes('git') || content.includes('ギット') || content.includes('github')) {
  recommendedProduct = {
    name: 'Gitチートシート完全版',
    price: '¥680',
    url: 'https://ezark-devtools.booth.pm/items/7967995'
  };
} else if (content.includes('docker') || content.includes('ドッカー') || content.includes('コンテナ')) {
  recommendedProduct = {
    name: 'Dockerチートシート完全版',
    price: '¥680',
    url: 'https://ezark-devtools.booth.pm/items/7968003'
  };
} else if (content.includes('typescript') || content.includes('タイプスクリプト')) {
  recommendedProduct = {
    name: 'TypeScript完全チートシート',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968018'
  };
} else if (content.includes('next.js') || content.includes('nextjs') || content.includes('ネクスト')) {
  recommendedProduct = {
    name: 'Next.js完全チートシート',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968038'
  };
} else if (content.includes('css') || content.includes('tailwind') || content.includes('テイルウィンド') || content.includes('スタイル')) {
  recommendedProduct = {
    name: 'CSS/Tailwind CSS完全チートシート',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968044'
  };
} else if (content.includes('aws') || content.includes('azure') || content.includes('gcp') || content.includes('cloud') || content.includes('クラウド')) {
  recommendedProduct = {
    name: 'クラウド完全チートシート',
    price: '¥980',
    url: 'https://ezark-devtools.booth.pm/items/7968049'
  };
} else {
  recommendedProduct = {
    name: '全商品セット（56%OFF）',
    price: '¥4,980',
    url: 'https://ezark-devtools.booth.pm/items/7968067'
  };
}
---

<aside class="product-cta">
  <section class="cta-section">
    <h3>📚 関連チートシート</h3>
    <div class="product-card">
      <div class="product-info">
        <h4>{recommendedProduct.name}</h4>
        <p class="product-price">{recommendedProduct.price}</p>
        <p class="product-description">
          実務で使える即戦力のチートシート。コマンド一覧、よく使うパターン、トラブルシューティングをまとめました。
        </p>
        <a href={recommendedProduct.url} class="cta-button" target="_blank" rel="noopener noreferrer">
          BOOTH で見る →
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h3>🛠️ この記事に関連するツール</h3>
    <div class="tools-card">
      <p>
        <strong>DevToolBox</strong> では無料の開発者ツールを公開中（全20ツール）。
        パスワード生成・カラーコード変換(HEX↔RGB↔HSL)・JSONフォーマッター・文字列ケース変換・CRONビルダー・UUID生成・正規表現テスターなど開発に役立つツールが揃っています。
      </p>
      <a href="https://usedevtools.com/" class="cta-button secondary" target="_blank" rel="noopener noreferrer">
        DevToolBox を見る →
      </a>
    </div>
  </section>
</aside>

<style>
  .product-cta {
    margin: 3rem 0;
    padding: 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    color: white;
  }

  .cta-section {
    margin-bottom: 2rem;
  }

  .cta-section:last-child {
    margin-bottom: 0;
  }

  .cta-section h3 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    font-weight: bold;
  }

  .product-card,
  .tools-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .product-info h4 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    font-weight: bold;
  }

  .product-price {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    font-weight: bold;
    color: #ffd700;
  }

  .product-description {
    margin: 0 0 1.5rem 0;
    line-height: 1.6;
    opacity: 0.9;
  }

  .tools-card p {
    margin: 0 0 1.5rem 0;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: white;
    color: #667eea;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid white;
  }

  .cta-button.secondary:hover {
    background: white;
    color: #667eea;
  }

  @media (max-width: 768px) {
    .product-cta {
      padding: 1.5rem;
      margin: 2rem 0;
    }

    .cta-section h3 {
      font-size: 1.25rem;
    }

    .product-info h4 {
      font-size: 1.1rem;
    }

    .product-price {
      font-size: 1.25rem;
    }

    .cta-button {
      display: block;
      text-align: center;
      width: 100%;
    }
  }
</style>
