---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<a href="/blog/">記事一覧</a>
			<a href="/blog/tags/">タグ</a>
			<a href="/about/">サイトについて</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--black, 255, 255, 255));
		border-bottom: 3px solid rgb(var(--gray-dark, 26, 31, 54));
	}
	h2 {
		margin: 0;
		font-size: 1.1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: auto;
		height: 3.25rem;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
	}
	.internal-links a {
		padding: 0.4rem 0.75rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 500;
		border-radius: 6px;
		transition: background 0.15s, color 0.15s;
	}
	.internal-links a:hover {
		background: rgb(var(--gray-light));
		color: rgb(var(--black));
	}
</style>
