---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-links">
			<div class="footer-col">
				<h3>コンテンツ</h3>
				<a href="/blog/">全記事一覧</a>
				<a href="/blog/tags/">タグ一覧</a>
				<a href="/about/">About</a>
			</div>
			<div class="footer-col">
				<h3>関連サイト</h3>
				<a href="https://ezark-consulting.com" target="_blank" rel="noopener noreferrer">イザークコンサルティング</a>
				<a href="https://usedevtools.com" target="_blank" rel="noopener noreferrer">DevToolBox</a>
				<a href="https://kaikei-ai.jp" target="_blank" rel="noopener noreferrer">Kaikei AI Daily</a>
			</div>
		</div>
		<div class="footer-bottom">
			<p>&copy; {year} イザークコンサルティング株式会社 All Rights Reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: var(--spacing-8);
		padding: var(--spacing-4) var(--spacing-2);
		border-top: 3px solid var(--color-outline);
		background: var(--color-surface);
		color: var(--color-on-surface);
	}

	[data-theme='dark'] footer,
	:root[data-theme='dark'] footer {
		background: var(--color-surface);
		border-color: var(--color-outline);
	}

	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
	}

	.footer-links {
		display: flex;
		gap: var(--spacing-6);
		margin-bottom: var(--spacing-4);
		flex-wrap: wrap;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.footer-col h3 {
		font-size: 0.875rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
		color: var(--color-on-surface);
	}

	.footer-col a {
		font-size: 0.8125rem;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.footer-col a:hover {
		color: var(--color-primary);
	}

	.footer-bottom {
		padding-top: var(--spacing-2);
		border-top: 1px solid rgba(var(--color-muted-rgb), 0.2);
	}

	.footer-bottom p {
		font-size: 0.75rem;
		color: var(--color-muted);
		text-align: center;
		margin: 0;
	}
</style>
