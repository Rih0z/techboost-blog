---
const today = new Date();
---

<footer>
	<div class="footer-services">
		<a href="https://note.com/ezark_company" target="_blank" rel="noopener noreferrer">note - AI実践ワークフロー</a>
		<span class="sep" aria-hidden="true">|</span>
		<a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener noreferrer">BOOTH - チートシート・テンプレート</a>
		<span class="sep" aria-hidden="true">|</span>
		<a href="https://usedevtools.com/" target="_blank" rel="noopener noreferrer">DevToolBox - 無料開発ツール</a>
		<span class="sep" aria-hidden="true">|</span>
		<a href="https://kaikei-ai.jp/" target="_blank" rel="noopener noreferrer">Kaikei AI Daily - 会計×AIニュース</a>
	</div>
	<nav class="footer-nav" aria-label="フッターナビゲーション">
		<a href="/privacy/">プライバシーポリシー</a>
		<a href="/terms/">利用規約</a>
		<a href="/about/">このブログについて</a>
		<a href="/contact/">お問い合わせ</a>
	</nav>
	<p class="copyright">
		&copy; 2025-{today.getFullYear()} イザークコンサルティング株式会社. All rights reserved.
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-nav {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		flex-wrap: wrap;
		margin-bottom: 1em;
	}
	.footer-nav a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.875rem;
	}
	.footer-nav a:hover {
		color: rgb(var(--gray-dark));
		text-decoration: underline;
	}
	.copyright {
		font-size: 0.8125rem;
		margin: 0;
	}
	.footer-services {
		display: flex;
		justify-content: center;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 1.25em;
		padding-bottom: 1.25em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.footer-services a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.8125rem;
		font-weight: 500;
		transition: color 0.15s;
	}
	.footer-services a:hover {
		color: rgb(var(--accent));
		text-decoration: underline;
	}
	.footer-services .sep {
		color: rgb(var(--gray-light));
		font-size: 0.75rem;
	}
	@media (max-width: 640px) {
		.footer-services {
			flex-direction: column;
			align-items: center;
			gap: 0.375em;
		}
		.footer-services .sep {
			display: none;
		}
	}
</style>
