---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-content">
		<div class="footer-links">
			<div class="footer-col">
				<h4>TechBoost</h4>
				<ul>
					<li><a href="/">ホーム</a></li>
					<li><a href="/blog/">記事一覧</a></li>
					<li><a href="/blog/tags/">タグ一覧</a></li>
					<li><a href="/about/">サイトについて</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>カテゴリ</h4>
				<ul>
					<li><a href="/blog/tag/TypeScript/">TypeScript</a></li>
					<li><a href="/blog/tag/React/">React</a></li>
					<li><a href="/blog/tag/Next.js/">Next.js</a></li>
					<li><a href="/blog/tag/career/">キャリア</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>関連サイト</h4>
				<ul>
					<li><a href="https://usedevtools.com/" target="_blank" rel="noopener">DevToolBox</a></li>
					<li><a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener">BOOTH</a></li>
					<li><a href="https://note.com/ezark_company" target="_blank" rel="noopener">note</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>法的情報</h4>
				<ul>
					<li><a href="/privacy/">プライバシーポリシー</a></li>
					<li><a href="/terms/">利用規約</a></li>
					<li><a href="/contact/">お問い合わせ</a></li>
				</ul>
			</div>
		</div>
		<div class="footer-bottom">
			<p>&copy; {currentYear} TechBoost. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 2rem;
		padding: 2.5rem 1rem 1.5rem;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}
	.footer-content {
		max-width: 1024px;
		margin: 0 auto;
	}
	.footer-links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 2rem;
		margin-bottom: 2rem;
	}
	.footer-col h4 {
		font-size: 0.9rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
		color: rgb(var(--black));
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col li {
		margin-bottom: 0.4rem;
	}
	.footer-col a {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-col a:hover {
		color: rgb(var(--accent));
	}
	.footer-bottom {
		border-top: 1px solid rgb(var(--gray) / 0.2);
		padding-top: 1rem;
		text-align: center;
	}
	.footer-bottom p {
		font-size: 0.8rem;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
